# Copy this file to ".env" and fill in your Supabase connection string.
# (.env is gitignored so your real credentials are never committed.)
#
# Where to find it: Supabase dashboard → your project → Connect (top bar)
# → "Session pooler" connection string. It looks like:
#   postgresql://postgres.abcdefgh:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

DATABASE_URL=

# Port the Express API listens on.
PORT=4000

# Optional: n8n webhook for the AI Study Help feature (leave empty to use
# the built-in keyword matching instead). Done by Khaing Khant Zaw.
N8N_WEBHOOK_URL=

# Optional: sign-up email verification (OTP). Leave BOTH empty to use the
# on-screen demo code instead of real Gmail delivery.
#   EMAIL_OTP_SECRET     — any long random string; signs the stateless token.
#   N8N_OTP_WEBHOOK_URL  — n8n workflow that emails the 6-digit code via Gmail.
EMAIL_OTP_SECRET=
N8N_OTP_WEBHOOK_URL=
